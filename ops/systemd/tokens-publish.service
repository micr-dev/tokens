[Unit]
Description=Publish tokens.micr.dev data from local histories
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/.local/share/tokens-publish/repo
Environment=HOME=%h
Environment=PATH=%h/.bun/bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env bun scripts/auto-publish-web.ts
