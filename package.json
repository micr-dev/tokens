{
  "name": "codegraph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "codegraph-usage": "./dist/cli.js"
  },
