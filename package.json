{
  "name": "slopmeter",
  "private": true,
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=slopmeter",
    "dev:web": "turbo run dev --filter=slopmeter-web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "publish:web": "bun run --cwd packages/web publish:usage",
    "typecheck": "turbo run typecheck",
    "check": "turbo run typecheck build",
    "start": "turbo run start --filter=slopmeter",
    "start:web": "turbo run start --filter=slopmeter-web"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.7.2"
  }
}
