{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "APPDATA",
        "CI",
        "CLAUDE_CONFIG_DIR",
        "CODEX_HOME",
        "CURSOR_CONFIG_DIR",
        "CURSOR_STATE_DB_PATH",
        "CURSOR_WEB_BASE_URL",
        "NODE_ENV",
        "OPENCODE_DATA_DIR",
        "PI_CODING_AGENT_DIR",
        "SLOPMETER_WEB_DATA_URL",
        "SLOPMETER_WEB_IMPORT_PATH",
        "SLOPMETER_FILE_PROCESS_CONCURRENCY",
        "SLOPMETER_MAX_JSONL_RECORD_BYTES",
        "XDG_CONFIG_HOME"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "APPDATA",
        "CLAUDE_CONFIG_DIR",
        "CODEX_HOME",
        "CURSOR_CONFIG_DIR",
        "CURSOR_STATE_DB_PATH",
        "CURSOR_WEB_BASE_URL",
        "NODE_ENV",
        "OPENCODE_DATA_DIR",
        "PI_CODING_AGENT_DIR",
        "SLOPMETER_WEB_DATA_URL",
        "SLOPMETER_WEB_IMPORT_PATH",
        "SLOPMETER_FILE_PROCESS_CONCURRENCY",
        "SLOPMETER_MAX_JSONL_RECORD_BYTES",
        "XDG_CONFIG_HOME"
      ]
    },
    "start": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["^lint:fix"]
    }
  }
}
